<div class="mb-6">
  <h1 class="text-2xl font-bold" style="color:#002776;">Pagamento</h1>
  <%= link_to "← Voltar", admin_payments_path, class: "text-sm text-gray-500 hover:underline" %>
</div>

<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
  <div class="bg-white rounded-xl shadow-sm border p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Detalhes</h2>
    <dl class="space-y-3 text-sm">
      <div class="flex justify-between"><dt class="text-gray-500">Participante</dt><dd class="font-medium"><%= @payment.user.name %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">E-mail</dt><dd><%= @payment.user.email %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Jogo</dt><dd class="font-medium"><%= @payment.match.home_team %> x <%= @payment.match.away_team %></dd></div>
      <div class="flex justify-between"><dt class="text-gray-500">Palpite</dt><dd><%= @payment.bet.home_score %> x <%= @payment.bet.away_score %></dd></div>
      <div class="flex justify-between">
        <dt class="text-gray-500">Valor</dt>
        <dd class="font-bold" style="color:#009C3B;">R$ <%= number_with_precision(@payment.amount, precision: 2, separator: ',', delimiter: '.') %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">Status</dt>
        <dd>
          <%
            status_pt = if @payment.refund_requested?
              ["⏳ Aguardando reembolso", "#fef3c7", "#92400e"]
            else
              { "pending"   => ["Aguardando PIX",        "#fef3c7", "#92400e"],
                "submitted" => ["Comprovante enviado",    "#dbeafe", "#1d4ed8"],
                "confirmed" => ["Pagamento confirmado ✓", "#dcfce7", "#15803d"],
                "rejected"  => ["Rejeitado",              "#fee2e2", "#dc2626"],
                "refunded"  => ["Reembolsado",            "#f3f4f6", "#6b7280"] }[@payment.status]
            end
          %>
          <span style="font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; background:<%= status_pt[1] %>; color:<%= status_pt[2] %>;">
            <%= status_pt[0] %>
          </span>
        </dd>
      </div>
    </dl>

    <div class="mt-6 space-y-3">
      <% if @payment.submitted? %>
        <%= button_to "✓ Confirmar pagamento", confirm_admin_payment_path(@payment), method: :patch,
              class: "w-full py-2.5 rounded-lg text-sm font-semibold text-white", style: "background-color:#009C3B;" %>

        <%# Rejeição com justificativa %>
        <div style="border:1px solid #fecaca; border-radius:10px; padding:16px; background:#fff5f5; margin-top:8px;">
          <p style="font-size:12px; font-weight:600; color:#dc2626; margin-bottom:8px;">Rejeitar comprovante</p>
          <%= form_with url: reject_admin_payment_path(@payment), method: :patch do |f| %>
            <div style="margin-bottom:10px;">
              <%= f.label :rejection_reason, "Motivo (opcional — será enviado por e-mail ao participante)",
                    style: "display:block; font-size:12px; color:#374151; margin-bottom:4px;" %>
              <%= f.text_area :rejection_reason, rows: 2,
                    placeholder: "Ex: Imagem ilegível, valor incorreto...",
                    style: "width:100%; border:1px solid #fca5a5; border-radius:6px; padding:8px; font-size:13px; resize:vertical; font-family:inherit; box-sizing:border-box;" %>
            </div>
            <%= f.submit "✗ Rejeitar pagamento",
                  style: "width:100%; padding:9px; border-radius:8px; font-size:13px; font-weight:600; color:#fff; border:none; cursor:pointer; background:#dc2626;" %>
          <% end %>
        </div>
      <% end %>
      <% if @payment.refund_requested? %>
        <%= button_to "Processar reembolso", process_refund_admin_payment_path(@payment), method: :patch,
              class: "w-full py-2.5 rounded-lg text-sm font-semibold text-white", style: "background-color:#002776;" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border p-6">
    <h2 class="font-semibold text-gray-800 mb-4">Comprovante</h2>
    <% if @payment.proof_url.present? %>
      <%= link_to "Ver comprovante →", view_proof_admin_payment_path(@payment), target: "_blank",
            style: "display:inline-block; font-size:13px; font-weight:600; color:#002776; margin-bottom:12px;" %>
    <% else %>
      <p class="text-sm text-gray-400">Nenhum comprovante enviado ainda.</p>
    <% end %>
  </div>
</div>
