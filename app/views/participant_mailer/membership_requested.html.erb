<p style="font-size:15px; color:#374151; margin:0 0 16px;">Olá, <strong><%= @admin.name.split.first %></strong>! 👋</p>

<div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:20px; margin-bottom:24px;">
  <p style="margin:0; font-size:16px; font-weight:700; color:#1d4ed8;">📋 Nova solicitação de entrada</p>
  <p style="margin:8px 0 0; font-size:14px; color:#1e40af;">
    Um participante quer entrar no bolão <strong><%= @pool.name %></strong> e aguarda sua aprovação.
  </p>
</div>

<table style="width:100%; border-collapse:collapse; margin-bottom:24px;">
  <tr style="background:#f8fafc;">
    <td style="padding:12px 16px; font-size:13px; color:#6b7280; border-bottom:1px solid #e2e8f0; width:35%;">Participante</td>
    <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#111827; border-bottom:1px solid #e2e8f0;"><%= @user.name %></td>
  </tr>
  <tr>
    <td style="padding:12px 16px; font-size:13px; color:#6b7280; border-bottom:1px solid #e2e8f0;">E-mail</td>
    <td style="padding:12px 16px; font-size:13px; color:#374151; border-bottom:1px solid #e2e8f0;"><%= @user.email %></td>
  </tr>
  <tr style="background:#f8fafc;">
    <td style="padding:12px 16px; font-size:13px; color:#6b7280;">Bolão</td>
    <td style="padding:12px 16px; font-size:13px; font-weight:600; color:#111827;"><%= @pool.name %></td>
  </tr>
</table>

<table cellpadding="0" cellspacing="0" style="margin:0 auto 24px;">
  <tr>
    <td style="background:#002776; border-radius:8px; padding:12px 28px;">
      <a href="<%= admin_pool_pool_memberships_url(@pool) %>" style="color:#ffffff; font-size:14px; font-weight:700; text-decoration:none;">
        Aprovar ou rejeitar →
      </a>
    </td>
  </tr>
</table>
