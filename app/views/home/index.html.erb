<% # Participant dashboard %>

<div style="margin-bottom:28px;">
  <h1 style="font-size:24px; font-weight:700; color:#002776;">
    Olá, <%= current_user.name.split.first %>! 👋
  </h1>
  <p style="font-size:14px; color:#6b7280; margin-top:4px;">Seus bolões e apostas da Copa 2026.</p>
</div>

<%# Bolões section %>
<div style="margin-bottom:32px;">
  <h2 style="font-size:16px; font-weight:600; color:#111827; margin-bottom:16px;">Seus bolões</h2>

  <% if @memberships.any? %>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px;">
      <% @memberships.each do |membership| %>
        <% pool = membership.pool %>
        <div style="background:#fff; border-radius:12px; border:1px solid #e5e7eb; padding:20px; box-shadow:0 1px 3px rgba(0,0,0,.06); border-top:3px solid <%= membership.approved? ? '#009C3B' : membership.pending? ? '#d97706' : '#dc2626' %>;">
          <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:12px;">
            <div>
              <p style="font-size:15px; font-weight:600; color:#111827;"><%= pool.name %></p>
              <% if pool.description.present? %>
                <p style="font-size:12px; color:#9ca3af; margin-top:2px;"><%= truncate(pool.description, length: 60) %></p>
              <% end %>
            </div>
            <%
              badge = case membership.status
                when "approved"  then ["#dcfce7", "#15803d", "Membro"]
                when "pending"   then ["#fef3c7", "#92400e", "Aguardando"]
                else                  ["#fee2e2", "#dc2626", "Rejeitado"]
              end
            %>
            <span style="font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; background:<%= badge[0] %>; color:<%= badge[1] %>; white-space:nowrap; margin-left:8px;"><%= badge[2] %></span>
          </div>

          <div style="font-size:12px; color:#6b7280; margin-bottom:16px;">
            Aposta mín.:
            <strong style="color:#009C3B;">R$ <%= number_with_precision(pool.min_bet_amount, precision: 2, separator: ',', delimiter: '.') %></strong>
            · <%= pool.matches.count %> jogo(s)
          </div>

          <% if membership.approved? %>
            <%= link_to "Ver jogos →", pool_path(pool),
                  style: "display:inline-block; padding:7px 16px; border-radius:8px; font-size:13px; font-weight:600; color:#fff; background:#009C3B; text-decoration:none;" %>
          <% elsif membership.pending? %>
            <p style="font-size:12px; color:#d97706;">⏳ Aguardando aprovação do organizador</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div style="background:#fff; border-radius:12px; border:1px dashed #d1d5db; padding:40px; text-align:center;">
      <p style="font-size:32px; margin-bottom:12px;">⚽</p>
      <p style="font-size:15px; font-weight:500; color:#374151; margin-bottom:4px;">Você ainda não está em nenhum bolão</p>
      <p style="font-size:13px; color:#9ca3af;">Peça o link de convite para o organizador</p>
    </div>
  <% end %>
</div>

<%# Apostas recentes %>
<% if @recent_bets.any? %>
  <div>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <h2 style="font-size:16px; font-weight:600; color:#111827;">Apostas recentes</h2>
      <%= link_to "Ver todas →", bets_path, style: "font-size:13px; color:#009C3B; font-weight:500; text-decoration:none;" %>
    </div>
    <div style="background:#fff; border-radius:12px; border:1px solid #e5e7eb; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.06);">
      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr style="background:#f9fafb; border-bottom:1px solid #e5e7eb;">
            <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Jogo</th>
            <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Seu palpite</th>
            <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Pagamento</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_bets.each do |bet| %>
            <tr style="border-bottom:1px solid #f3f4f6;">
              <td style="padding:14px 20px;">
                <p style="font-size:13px; font-weight:500; color:#111827;"><%= bet.match.home_team %> x <%= bet.match.away_team %></p>
                <p style="font-size:12px; color:#9ca3af;"><%= bet.match.pool.name %></p>
              </td>
              <td style="padding:14px 20px; font-size:18px; font-weight:700; color:#002776; font-variant-numeric:tabular-nums;">
                <%= bet.home_score %> × <%= bet.away_score %>
              </td>
              <td style="padding:14px 20px;">
                <% p = bet.payment %>
                <% if p %>
                  <%
                    ps = if p.refund_requested?
                      ["#fef3c7","#92400e","⏳ Aguardando reembolso"]
                    else
                      { "pending"   => ["#fef3c7","#92400e","Aguardando PIX"],
                        "submitted" => ["#dbeafe","#1d4ed8","Comprovante enviado"],
                        "confirmed" => ["#dcfce7","#15803d","Confirmado ✓"],
                        "rejected"  => ["#fee2e2","#dc2626","Rejeitado"],
                        "refunded"  => ["#f3f4f6","#6b7280","Reembolsado"] }[p.status]
                    end
                  %>
                  <span style="font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; background:<%= ps[0] %>; color:<%= ps[1] %>;"><%= ps[2] %></span>
                <% end %>
              </td>
              <td style="padding:14px 20px; text-align:right;">
                <% if bet.payment && !bet.payment.refund_requested? && (bet.payment.pending? || bet.payment.submitted?) %>
                  <%= link_to "Pagar →", payment_path(bet.payment), style: "font-size:12px; font-weight:600; color:#009C3B; text-decoration:none;" %>
                <% elsif !bet.payment&.refund_requested? %>
                  <%= link_to "Ver", bet_path(bet), style: "font-size:12px; color:#6b7280; text-decoration:none;" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>
