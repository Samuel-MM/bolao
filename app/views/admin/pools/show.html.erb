<% content_for :page_title, @pool.name %>

<div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:20px;">
  <div>
    <%= link_to "← Bolões", admin_pools_path, style: "font-size:13px; color:#6b7280; text-decoration:none;" %>
    <div style="margin-top:8px; display:flex; align-items:center; gap:12px;">
      <h2 style="font-size:22px; font-weight:700; color:#111827;"><%= @pool.name %></h2>
      <% if @pool.open? %>
        <span style="background:#dcfce7; color:#15803d; font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px;">Aberto</span>
      <% else %>
        <span style="background:#f3f4f6; color:#6b7280; font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px;">Encerrado</span>
      <% end %>
    </div>
    <div style="margin-top:8px; display:flex; align-items:center; gap:8px;">
      <span style="font-size:12px; color:#6b7280;">Link de convite:</span>
      <code style="font-size:11px; background:#f3f4f6; padding:3px 8px; border-radius:6px; color:#374151;"><%= pool_invite_url(@pool.invite_token) %></code>
    </div>
  </div>
  <div style="display:flex; gap:8px;">
    <%= link_to "Editar", edit_admin_pool_path(@pool),
          style: "padding:8px 16px; border-radius:8px; font-size:13px; font-weight:500; color:#374151; border:1px solid #d1d5db; background:#fff; text-decoration:none;" %>
    <%= button_to "Excluir", admin_pool_path(@pool), method: :delete,
          style: "padding:8px 16px; border-radius:8px; font-size:13px; font-weight:500; color:#fff; border:none; cursor:pointer; background:#dc2626;",
          data: { confirm: "Remover este bolão e todos os seus dados?" } %>
  </div>
</div>

<%# Jogos %>
<div style="background:#fff; border-radius:12px; border:1px solid #e5e7eb; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.06); margin-bottom:20px;">
  <div style="padding:16px 20px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; justify-content:space-between;">
    <h3 style="font-size:14px; font-weight:600; color:#111827;">Jogos (<%= @matches.count %>)</h3>
    <%= link_to "＋ Adicionar jogo", new_admin_pool_match_path(@pool),
          style: "font-size:12px; font-weight:600; color:#fff; padding:6px 14px; border-radius:6px; background:#009C3B; text-decoration:none;" %>
  </div>
  <% if @matches.any? %>
    <table style="width:100%; border-collapse:collapse;">
      <thead>
        <tr style="background:#f9fafb; border-bottom:1px solid #e5e7eb;">
          <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Jogo</th>
          <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Data/Hora</th>
          <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Status</th>
          <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Resultado</th>
          <th style="padding:10px 20px; text-align:left; font-size:11px; font-weight:600; color:#6b7280; text-transform:uppercase; letter-spacing:.05em;">Apostas</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @matches.each do |m| %>
          <tr style="border-bottom:1px solid #f3f4f6;">
            <td style="padding:14px 20px; font-size:14px; font-weight:500; color:#111827;">
              🇧🇷 <%= m.home_team %> <span style="color:#9ca3af; margin:0 4px;">×</span> <%= m.away_team %>
            </td>
            <td style="padding:14px 20px; font-size:13px; color:#374151;"><%= m.kickoff_at.strftime("%d/%m/%Y %H:%M") %></td>
            <td style="padding:14px 20px;">
              <%
                status_styles = {
                  "scheduled" => "background:#dbeafe; color:#1d4ed8;",
                  "live"      => "background:#dcfce7; color:#15803d;",
                  "finished"  => "background:#f3f4f6; color:#6b7280;",
                  "cancelled" => "background:#fee2e2; color:#dc2626;"
                }
                status_labels = { "scheduled" => "Agendado", "live" => "Ao vivo", "finished" => "Encerrado", "cancelled" => "Cancelado" }
              %>
              <span style="font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; <%= status_styles[m.status] %>">
                <%= status_labels[m.status] %>
              </span>
            </td>
            <td style="padding:14px 20px; font-size:14px; font-weight:700; color:<%= m.finished? ? '#009C3B' : '#9ca3af' %>">
              <%= m.finished? ? "#{m.home_score} × #{m.away_score}" : "—" %>
            </td>
            <td style="padding:14px 20px; font-size:13px; color:#374151;"><%= m.bets.count %></td>
            <td style="padding:14px 20px;">
              <div style="display:flex; gap:12px; justify-content:flex-end;">
                <%= link_to "Editar", edit_admin_pool_match_path(@pool, m), style: "font-size:12px; color:#6b7280; text-decoration:none;" %>
                <% if m.api_football_id.present? %>
                  <%= button_to "Sync", sync_result_admin_pool_match_path(@pool, m), method: :post,
                        style: "font-size:12px; color:#002776; background:none; border:none; cursor:pointer; padding:0;" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="padding:32px; text-align:center; font-size:13px; color:#9ca3af;">Nenhum jogo cadastrado.</p>
  <% end %>
</div>

<%# Membros %>
<div style="background:#fff; border-radius:12px; border:1px solid #e5e7eb; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.06);">
  <div style="padding:16px 20px; border-bottom:1px solid #f3f4f6; display:flex; align-items:center; justify-content:space-between;">
    <h3 style="font-size:14px; font-weight:600; color:#111827;">Participantes (<%= @memberships.count %>)</h3>
    <%= link_to "Gerenciar", admin_pool_pool_memberships_path(@pool),
          style: "font-size:12px; font-weight:500; color:#002776; text-decoration:none;" %>
  </div>
  <% if @memberships.any? %>
    <ul>
      <% @memberships.each do |m| %>
        <li style="padding:12px 20px; border-bottom:1px solid #f9fafb; display:flex; align-items:center; justify-content:space-between;">
          <div style="display:flex; align-items:center; gap:10px;">
            <div style="width:32px; height:32px; border-radius:50%; background:#f3f4f6; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; color:#374151;">
              <%= m.user.name[0].upcase %>
            </div>
            <div>
              <p style="font-size:13px; font-weight:500; color:#111827;"><%= m.user.name %></p>
              <p style="font-size:12px; color:#9ca3af;"><%= m.user.email %></p>
            </div>
          </div>
          <%
            badge = { "pending" => ["#fef3c7", "#92400e", "Pendente"], "approved" => ["#dcfce7", "#15803d", "Aprovado"], "rejected" => ["#fee2e2", "#dc2626", "Rejeitado"] }[m.status]
          %>
          <span style="font-size:11px; font-weight:600; padding:3px 10px; border-radius:99px; background:<%= badge[0] %>; color:<%= badge[1] %>;"><%= badge[2] %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p style="padding:32px; text-align:center; font-size:13px; color:#9ca3af;">Nenhum participante ainda.</p>
  <% end %>
</div>
