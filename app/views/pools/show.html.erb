<div class="mb-6">
  <h1 class="text-2xl font-bold" style="color:#002776;"><%= @pool.name %></h1>
  <% if @pool.description.present? %>
    <p class="text-gray-500 text-sm mt-1"><%= @pool.description %></p>
  <% end %>
</div>

<div class="bg-white rounded-xl border shadow-sm overflow-hidden">
  <div class="px-5 py-4 border-b">
    <h2 class="font-semibold text-gray-800">Jogos</h2>
  </div>
  <% if @matches.any? %>
    <div class="divide-y">
      <% @matches.each do |match| %>
        <div class="px-5 py-4 flex items-center justify-between">
          <div>
            <p class="font-medium text-gray-800 flex items-center gap-1.5">
              <% if match.home_crest.present? %>
                <img src="<%= match.home_crest %>" alt="" style="width:20px;height:20px;object-fit:contain;">
              <% end %>
              <%= match.home_team %>
              <span class="text-gray-400 mx-0.5">vs</span>
              <%= match.away_team %>
              <% if match.away_crest.present? %>
                <img src="<%= match.away_crest %>" alt="" style="width:20px;height:20px;object-fit:contain;">
              <% end %>
            </p>
            <p class="text-xs text-gray-500 mt-0.5"><%= match.kickoff_at.strftime("%d/%m/%Y às %H:%M") %></p>
            <% if match.finished? %>
              <p class="text-xs font-semibold mt-1" style="color:#009C3B;">
                Resultado: <%= match.home_score %> x <%= match.away_score %>
              </p>
            <% end %>
          </div>
          <div class="text-right">
            <% if match.bets_open? %>
              <span class="block text-xs text-green-600 font-medium mb-2">Apostas abertas</span>
              <%= link_to "Apostar", new_pool_match_bet_path(@pool, match),
                    class: "px-4 py-1.5 rounded-lg text-xs font-semibold text-white",
                    style: "background-color:#009C3B;" %>
            <% elsif match.finished? %>
              <span class="block text-xs text-gray-500 mb-2">Encerrado</span>
              <%= link_to "Ver resultado", pool_match_path(@pool, match),
                    class: "px-4 py-1.5 rounded-lg text-xs font-medium border border-gray-300 text-gray-600 hover:bg-gray-50" %>
            <% else %>
              <span class="block text-xs text-yellow-600 font-medium">Apostas encerradas</span>
              <span class="block text-xs text-gray-400 mt-1">Jogo em breve</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="px-5 py-8 text-center text-gray-400">Nenhum jogo cadastrado ainda.</p>
  <% end %>
</div>
