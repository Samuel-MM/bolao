<div class="max-w-xl mx-auto">
  <div class="mb-8">
    <h1 class="text-2xl font-bold" style="color:#002776;">Minha conta</h1>
    <p class="text-sm text-gray-500 mt-1">Gerencie suas informações pessoais e dados de pagamento</p>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <div class="space-y-5">

        <div>
          <%= f.label :name, "Nome completo", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name",
              class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
        </div>

        <div>
          <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
        </div>

        <div>
          <div class="flex items-center justify-between">
            <%= f.label :pix_key, "Chave PIX para receber prêmio", class: "block text-sm font-medium text-gray-700" %>
            <span class="text-xs text-gray-400">Opcional</span>
          </div>
          <p class="text-xs text-gray-500 mt-0.5">CPF, telefone, e-mail ou chave aleatória. Usada para transferir o prêmio caso você vença.</p>
          <%= f.text_field :pix_key, placeholder: "Ex: 11999999999",
              class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
        </div>

        <div style="border-top:1px solid #f1f5f9; padding-top:20px;">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-4">Alterar senha</p>

          <div class="space-y-4">
            <div>
              <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-gray-700" %>
              <p class="text-xs text-gray-400 mt-0.5">Deixe em branco para manter a senha atual</p>
              <%= f.password_field :password, autocomplete: "new-password",
                  class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
            </div>

            <div>
              <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-gray-700" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password",
                  class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
            </div>
          </div>
        </div>

        <div style="border-top:1px solid #f1f5f9; padding-top:20px;">
          <div>
            <%= f.label :current_password, "Senha atual", class: "block text-sm font-medium text-gray-700" %>
            <p class="text-xs text-gray-400 mt-0.5">Necessária para confirmar qualquer alteração</p>
            <%= f.password_field :current_password, autocomplete: "current-password",
                class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
          </div>
        </div>

        <%= f.submit "Salvar alterações",
            class: "w-full flex justify-center py-2.5 px-4 rounded-lg text-sm font-semibold text-white cursor-pointer transition-opacity hover:opacity-90",
            style: "background-color:#009C3B;" %>
      </div>
    <% end %>
  </div>
</div>
