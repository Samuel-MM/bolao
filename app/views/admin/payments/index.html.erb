<div class="mb-6">
  <h1 class="text-2xl font-bold" style="color:#002776;">Pagamentos</h1>
</div>

<div class="bg-white rounded-xl shadow-sm border mb-6">
  <div class="px-5 py-4 border-b flex items-center justify-between">
    <h2 class="font-semibold text-gray-800">Aguardando confirmação</h2>
    <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full font-medium"><%= @submitted.count %></span>
  </div>
  <% if @submitted.any? %>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Participante</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Jogo</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Palpite</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Valor</th>
          <th></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @submitted.each do |p| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 font-medium text-gray-800"><%= p.user.name %></td>
            <td class="px-5 py-3 text-gray-600"><%= p.match.home_team %> x <%= p.match.away_team %></td>
            <td class="px-5 py-3 text-gray-600"><%= p.bet.home_score %> x <%= p.bet.away_score %></td>
            <td class="px-5 py-3 text-gray-600">R$ <%= number_with_precision(p.amount, precision: 2, separator: ',', delimiter: '.') %></td>
            <td class="px-5 py-3">
              <%= link_to "Analisar", admin_payment_path(p), class: "text-blue-600 hover:underline text-xs font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-8 text-center text-gray-400">Nenhum comprovante aguardando análise.</p>
  <% end %>
</div>

<% if @refund_requests.any? %>
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b">
      <h2 class="font-semibold text-gray-800">Reembolsos solicitados</h2>
    </div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Participante</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Jogo</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Valor</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Solicitado em</th>
          <th></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @refund_requests.each do |p| %>
          <tr class="hover:bg-gray-50">
            <td class="px-5 py-3 font-medium text-gray-800"><%= p.user.name %></td>
            <td class="px-5 py-3 text-gray-600"><%= p.match.home_team %> x <%= p.match.away_team %></td>
            <td class="px-5 py-3 text-gray-600">R$ <%= number_with_precision(p.amount, precision: 2, separator: ',', delimiter: '.') %></td>
            <td class="px-5 py-3 text-gray-500 text-xs"><%= p.refund_requested_at.strftime("%d/%m %H:%M") %></td>
            <td class="px-5 py-3">
              <%= link_to "Processar", admin_payment_path(p), class: "text-blue-600 hover:underline text-xs font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
