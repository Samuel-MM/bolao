<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bolão da Copa" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bolao Da Copa">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>body { font-family: 'Inter', sans-serif; }</style>
  </head>

  <body class="bg-gray-50">
    <% if content_for?(:full_page) %>
      <%= yield %>
    <% else %>
      <!-- Nav -->
      <nav class="bg-white shadow-sm border-b">
        <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-14">
          <%= link_to root_path, class: "flex items-center gap-2" do %>
            <span class="text-xl">⚽</span>
            <span class="font-bold text-sm" style="color:#002776;">Bolão da Copa</span>
          <% end %>
          <div class="flex items-center gap-3 text-sm">
            <% if user_signed_in? %>
              <%= link_to "Minhas apostas", bets_path, class: "text-gray-600 hover:text-green-700 hidden sm:inline" %>
              <span class="text-gray-300 hidden sm:inline">|</span>
              <%= link_to "Minha conta", edit_user_registration_path, class: "text-gray-600 hover:text-green-700" %>
              <span class="text-gray-300">|</span>
              <span class="text-gray-700 font-medium hidden sm:inline"><%= current_user.name.split.first %></span>
              <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete },
                    class: "text-red-600 hover:underline" %>
            <% end %>
          </div>
        </div>
      </nav>

      <!-- Flash -->
      <div class="max-w-5xl mx-auto px-4 mt-4 space-y-2">
        <% flash.each do |type, message| %>
          <div class="px-4 py-3 rounded-lg text-sm font-medium shadow
            <%= type.to_s == 'alert' ? 'bg-red-100 text-red-800 border border-red-200' : 'bg-green-100 text-green-800 border border-green-200' %>">
            <%= message %>
          </div>
        <% end %>
      </div>

      <main class="max-w-5xl mx-auto px-4 py-6">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
