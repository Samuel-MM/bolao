<div class="mb-6">
  <h1 class="text-2xl font-bold" style="color:#002776;">Nova Aposta</h1>
  <p class="text-gray-500 text-sm mt-1">
    <%= @pool.name %> — <%= @match.home_team %> x <%= @match.away_team %>
    (<%= @match.kickoff_at.strftime("%d/%m às %H:%M") %>)
  </p>
</div>

<div class="bg-white rounded-xl border shadow-sm p-6 max-w-md">
  <%= form_with model: [@pool, @match, @bet], class: "space-y-6" do |f| %>
    <% if @bet.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-700">
        <ul class="list-disc list-inside space-y-1">
          <% @bet.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div class="text-center py-4 bg-gray-50 rounded-xl">
      <p class="text-xs text-gray-500 mb-3 font-medium uppercase tracking-wide">Seu palpite</p>
      <div class="flex items-center justify-center gap-4">
        <div class="text-center">
          <% if @match.home_crest.present? %>
            <img src="<%= @match.home_crest %>" alt="" style="width:32px;height:32px;object-fit:contain;margin:0 auto 4px;">
          <% end %>
          <p class="text-xs text-gray-500 mb-1 font-medium"><%= @match.home_team %></p>
          <%= f.number_field :home_score, min: 0, max: 20,
                class: "w-16 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg py-2 focus:outline-none focus:border-green-500",
                placeholder: "0" %>
        </div>
        <span class="text-2xl font-bold text-gray-400">×</span>
        <div class="text-center">
          <% if @match.away_crest.present? %>
            <img src="<%= @match.away_crest %>" alt="" style="width:32px;height:32px;object-fit:contain;margin:0 auto 4px;">
          <% end %>
          <p class="text-xs text-gray-500 mb-1 font-medium"><%= @match.away_team %></p>
          <%= f.number_field :away_score, min: 0, max: 20,
                class: "w-16 text-center text-2xl font-bold border-2 border-gray-300 rounded-lg py-2 focus:outline-none focus:border-green-500",
                placeholder: "0" %>
        </div>
      </div>
    </div>

    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-sm">
      <p class="font-semibold text-yellow-800 mb-1">Valor da aposta</p>
      <p class="text-yellow-700">
        R$ <%= number_with_precision(@pool.min_bet_amount, precision: 2, separator: ',', delimiter: '.') %>
        (pagamento via PIX após confirmar)
      </p>
    </div>

    <%= f.submit "Confirmar aposta →",
          class: "w-full py-3 rounded-lg text-sm font-semibold text-white cursor-pointer transition-opacity hover:opacity-90",
          style: "background-color:#009C3B;" %>
    <%= link_to "Cancelar", pool_path(@pool), class: "block text-center text-sm text-gray-500 hover:underline mt-2" %>
  <% end %>
</div>
