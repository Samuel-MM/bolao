<% content_for :page_title, "Apostas — #{@match.home_team} x #{@match.away_team}" %>

<div class="mb-6">
  <h1 class="text-2xl font-bold" style="color:#002776;">
    Apostas — <%= @match.home_team %> x <%= @match.away_team %>
  </h1>
  <%= link_to "← Voltar aos jogos", admin_pool_matches_path(@pool), class: "text-sm text-gray-500 hover:underline" %>
</div>

<%# Match summary card %>
<div class="bg-white rounded-xl shadow-sm border p-5 mb-6 flex flex-wrap gap-6 items-center">
  <div>
    <p class="text-xs text-gray-400 mb-0.5">Placar</p>
    <p class="text-lg font-bold text-gray-800">
      <% if @match.finished? %>
        <%= @match.home_score %> × <%= @match.away_score %>
      <% else %>
        —
      <% end %>
    </p>
  </div>
  <div>
    <p class="text-xs text-gray-400 mb-0.5">Status</p>
    <span class="px-2 py-0.5 rounded-full text-xs font-medium
      <%= @match.scheduled? ? 'bg-blue-100 text-blue-800' : @match.live? ? 'bg-green-100 text-green-800' : @match.finished? ? 'bg-gray-100 text-gray-600' : 'bg-red-100 text-red-700' %>">
      <%= { "scheduled" => "Agendado", "live" => "Ao vivo", "finished" => "Encerrado", "cancelled" => "Cancelado" }[@match.status] %>
    </span>
  </div>
  <div>
    <p class="text-xs text-gray-400 mb-0.5">Total de apostas</p>
    <p class="text-lg font-bold text-gray-800"><%= @bets.size %></p>
  </div>
  <div>
    <p class="text-xs text-gray-400 mb-0.5">Prêmio total</p>
    <p class="text-lg font-bold" style="color:#009C3B;">
      R$ <%= number_with_precision(@match.total_prize, precision: 2, separator: ',', delimiter: '.') %>
    </p>
  </div>
  <% if @match.finished? && @winning_ids.any? %>
    <div>
      <p class="text-xs text-gray-400 mb-0.5">Vencedores</p>
      <p class="text-lg font-bold" style="color:#009C3B;"><%= @winning_ids.size %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 mb-0.5">Prêmio por vencedor</p>
      <p class="text-lg font-bold" style="color:#009C3B;">
        R$ <%= number_with_precision((@match.total_prize / @winning_ids.size), precision: 2, separator: ',', delimiter: '.') %>
      </p>
    </div>
  <% end %>
</div>

<%# Winners highlighted section %>
<% if @match.finished? && @winning_ids.any? %>
  <div style="background:#f0fdf4; border:1px solid #86efac; border-radius:12px; padding:20px; margin-bottom:24px;">
    <p class="text-sm font-bold mb-3" style="color:#15803d;">🏆 Vencedores — Chaves PIX para pagamento</p>
    <div class="space-y-2">
      <% @bets.where(id: @winning_ids).each do |bet| %>
        <div class="flex flex-wrap items-center gap-3 bg-white rounded-lg px-4 py-3 border border-green-100">
          <span class="font-semibold text-gray-800 text-sm"><%= bet.user.name %></span>
          <span class="text-gray-400">·</span>
          <span class="text-sm text-gray-600"><%= bet.user.email %></span>
          <span class="text-gray-400">·</span>
          <% if bet.user.pix_key.present? %>
            <span class="font-mono text-sm font-semibold" style="color:#002776;">
              PIX: <%= bet.user.pix_key %>
            </span>
          <% else %>
            <span class="text-xs text-red-500 font-medium">⚠ Sem chave PIX cadastrada</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% elsif @match.finished? %>
  <div style="background:#fef9c3; border:1px solid #fde047; border-radius:12px; padding:16px; margin-bottom:24px;">
    <p class="text-sm font-medium" style="color:#854d0e;">Nenhum participante acertou o placar exato neste jogo.</p>
  </div>
<% end %>

<%# All bets table %>
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <div class="px-5 py-4 border-b">
    <h2 class="font-semibold text-gray-800">Todas as apostas <span class="text-gray-400 font-normal text-sm">· ordem cronológica</span></h2>
  </div>
  <% if @bets.any? %>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="px-5 py-3 text-left font-medium text-gray-600">#</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Participante</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Palpite</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Pagamento</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Chave PIX</th>
          <th class="px-5 py-3 text-left font-medium text-gray-600">Apostado em</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @bets.each_with_index do |bet, i| %>
          <% is_winner = @winning_ids.include?(bet.id) %>
          <tr class="<%= is_winner ? '' : 'hover:bg-gray-50' %>"
              style="<%= is_winner ? 'background:#f0fdf4;' : '' %>">
            <td class="px-5 py-3 text-gray-400 text-xs"><%= i + 1 %></td>
            <td class="px-5 py-3">
              <div class="flex items-center gap-2">
                <% if is_winner %>
                  <span title="Vencedor">🏆</span>
                <% end %>
                <span class="font-medium text-gray-800"><%= bet.user.name %></span>
              </div>
            </td>
            <td class="px-5 py-3">
              <span class="font-mono font-semibold <%= is_winner ? '' : 'text-gray-700' %>"
                    style="<%= is_winner ? 'color:#15803d;' : '' %>">
                <%= bet.home_score %> × <%= bet.away_score %>
              </span>
            </td>
            <td class="px-5 py-3">
              <% if bet.payment.nil? %>
                <span class="text-xs text-gray-400">Sem pagamento</span>
              <% else %>
                <%
                  p_label, p_color = {
                    "pending"   => ["Pendente",    "#92400e"],
                    "submitted" => ["Enviado",      "#1d4ed8"],
                    "confirmed" => ["Confirmado ✓", "#15803d"],
                    "rejected"  => ["Rejeitado",    "#dc2626"],
                    "refunded"  => ["Reembolsado",  "#6b7280"]
                  }[bet.payment.status]
                %>
                <span style="font-size:11px; font-weight:600; color:<%= p_color %>;">
                  <%= p_label %>
                </span>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <% if bet.user.pix_key.present? %>
                <span class="font-mono text-xs text-gray-700"><%= bet.user.pix_key %></span>
              <% else %>
                <span class="text-xs text-gray-300">—</span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-gray-500 text-xs"><%= bet.created_at.strftime("%d/%m %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-5 py-10 text-center text-gray-400">Nenhuma aposta registrada ainda.</p>
  <% end %>
</div>
