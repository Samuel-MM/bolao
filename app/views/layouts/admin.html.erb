<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title>Admin — <%= content_for(:title) || "Bolão da Copa" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..900;1,14..32,400..900&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      * { font-family: 'Inter', sans-serif; }
      .sidebar-link { display:flex; align-items:center; gap:8px; padding:8px 12px; border-radius:8px; font-size:14px; font-weight:500; color:#374151; transition:all .15s; text-decoration:none; }
      .sidebar-link:hover { background-color:#f0fdf4; color:#16a34a; }
      .sidebar-link.active { background-color:#dcfce7; color:#15803d; font-weight:600; }
      /* Mobile sidebar */
      .admin-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:25; }
      .admin-overlay.open { display:block; }
      .admin-sidebar-close-btn { display:none; }
      .admin-hamburger { display:none; }
      @media (max-width:767px) {
        .admin-sidebar { transform:translateX(-100%); transition:transform .25s ease; }
        .admin-sidebar.open { transform:translateX(0); }
        .admin-main { margin-left:0 !important; }
        .admin-hamburger { display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:8px; border:1px solid #e5e7eb; background:white; cursor:pointer; flex-shrink:0; }
        .admin-sidebar-close-btn { display:flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:6px; border:none; background:#f3f4f6; cursor:pointer; font-size:14px; color:#374151; flex-shrink:0; }
      }
    </style>
  </head>
  <body style="background-color:#f8fafc;" class="min-h-screen" data-controller="admin-sidebar">

    <%# Mobile overlay %>
    <div class="admin-overlay" data-admin-sidebar-target="overlay" data-action="click->admin-sidebar#close"></div>

    <div class="flex min-h-screen">

      <%# Sidebar %>
      <aside class="admin-sidebar w-60 bg-white border-r border-gray-200 flex flex-col flex-shrink-0 fixed inset-y-0 left-0 z-30" data-admin-sidebar-target="sidebar">
        <%# Logo %>
        <div class="flex items-center gap-3 px-5 h-16 border-b border-gray-200">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-lg flex-shrink-0" style="background-color:#009C3B;">⚽</div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-bold" style="color:#002776;">Bolão da Copa</p>
            <span class="text-xs font-semibold px-1.5 py-0.5 rounded text-white" style="background-color:#002776; font-size:10px;">ADMIN</span>
          </div>
          <button class="admin-sidebar-close-btn" data-action="click->admin-sidebar#close" aria-label="Fechar menu">✕</button>
        </div>

        <%# Nav %>
        <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-3 mb-2">Gestão</p>
          <%= link_to admin_dashboard_path,
                class: "sidebar-link #{request.path == admin_dashboard_path ? 'active' : ''}",
                data: { action: "click->admin-sidebar#close" } do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Dashboard
          <% end %>
          <%= link_to admin_pools_path,
                class: "sidebar-link #{request.path.start_with?('/admin/pools') ? 'active' : ''}",
                data: { action: "click->admin-sidebar#close" } do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Bolões
          <% end %>
          <%= link_to admin_payments_path,
                class: "sidebar-link #{request.path.start_with?('/admin/payments') ? 'active' : ''}",
                data: { action: "click->admin-sidebar#close" } do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Pagamentos
            <% if Payment.submitted.count > 0 %>
              <span class="ml-auto text-xs font-bold text-white rounded-full w-5 h-5 flex items-center justify-center" style="background-color:#dc2626; font-size:10px;"><%= Payment.submitted.count %></span>
            <% end %>
          <% end %>
        </nav>

        <%# User %>
        <div class="px-4 py-4 border-t border-gray-200">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0" style="background-color:#009C3B;">
              <%= current_user.name[0].upcase %>
            </div>
            <div class="min-w-0">
              <p class="text-sm font-semibold text-gray-800 truncate"><%= current_user.name %></p>
              <p class="text-xs text-gray-400 truncate"><%= current_user.email %></p>
            </div>
          </div>
          <%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete },
                class: "flex items-center gap-2 text-sm text-red-500 hover:text-red-700 font-medium" %>
        </div>
      </aside>

      <%# Main content (offset by sidebar width on desktop) %>
      <div class="admin-main flex-1 flex flex-col min-w-0 ml-60">
        <%# Top header %>
        <header class="h-16 bg-white border-b border-gray-200 flex items-center gap-3 px-4 sticky top-0 z-20">
          <button class="admin-hamburger" data-action="click->admin-sidebar#open" aria-label="Abrir menu">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <h1 class="text-base font-semibold text-gray-800 flex-1 truncate"><%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %></h1>
          <div class="flex items-center gap-2 text-xs text-gray-400 flex-shrink-0">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="hidden sm:inline"><%= Time.current.strftime("%d/%m/%Y %H:%M") %></span>
          </div>
        </header>

        <%# Flash %>
        <% flash.each do |type, message| %>
          <div class="mx-4 sm:mx-6 mt-4 px-4 py-3 rounded-lg text-sm font-medium
            <%= type.to_s == 'alert' ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200' %>">
            <%= message %>
          </div>
        <% end %>

        <main class="flex-1 p-4 sm:p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
