<% content_for :page_title, "Editar Bolão" %>

<div style="max-width:560px;">
  <%= link_to "← #{@pool.name}", admin_pool_path(@pool), style: "font-size:13px; color:#6b7280; text-decoration:none; display:inline-block; margin-bottom:16px;" %>
  <div style="background:#fff; border-radius:12px; border:1px solid #e5e7eb; padding:28px; box-shadow:0 1px 3px rgba(0,0,0,.06);">
    <h2 style="font-size:18px; font-weight:700; color:#111827; margin-bottom:20px;">Editar bolão</h2>
    <%= render "form", pool: @pool %>
  </div>
</div>
