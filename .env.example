# Banco de dados (Docker)
DATABASE_URL=postgresql://bolao:bolao@db:5432/bolao_da_copa_production
DB_HOST=localhost
DB_PORT=5433
DB_USER=bolao
DB_PASSWORD=bolao

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=rode_rails_secret_e_cole_aqui
RAILS_MASTER_KEY=conteudo_de_config/master.key
APP_HOST=localhost

# PIX
PIX_KEY=seu_numero_pix
PIX_MERCHANT_NAME=Seu Nome
PIX_MERCHANT_CITY=Sua Cidade

# AWS S3 (comprovantes de pagamento)
AWS_ACCESS_KEY_ID=SUA_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=SUA_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=nome-do-seu-bucket

# API Football
API_FOOTBALL_KEY=sua_chave_api_football

# E-mail (Gmail App Password)
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu@gmail.com
SMTP_PASSWORD=sua_app_password_sem_espacos
MAILER_FROM=seu@gmail.com

# Docker Hub
DOCKERHUB_USERNAME=seu_usuario_dockerhub
