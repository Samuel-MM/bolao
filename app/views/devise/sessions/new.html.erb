<% content_for :full_page, true %>
<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center mb-4">
      <div class="w-16 h-16 rounded-full flex items-center justify-center" style="background-color:#009C3B;">
        <span class="text-3xl">⚽</span>
      </div>
    </div>
    <h2 class="text-center text-3xl font-extrabold" style="color:#002776;">Bolão da Copa</h2>
    <p class="mt-2 text-center text-sm text-gray-500">Entre na sua conta</p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-6 shadow rounded-xl sm:px-10">
      <% if session[:invite_pool_name].present? %>
        <div style="background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:14px 16px; margin-bottom:20px;">
          <p class="text-sm font-semibold" style="color:#1d4ed8; margin-bottom:4px;">Você foi convidado!</p>
          <p class="text-sm text-gray-600">
            Entre na sua conta para participar do bolão <strong><%= session[:invite_pool_name] %></strong>.
            Não tem conta? <%= link_to "Crie uma gratuitamente", new_user_registration_path, style: "color:#1d4ed8; text-decoration:underline;" %>.
          </p>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-5">
          <div>
            <%= f.label :email, "E-mail", class: "block text-sm font-medium text-gray-700" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2",
                style: "focus-ring-color:#009C3B;" %>
          </div>

          <div>
            <%= f.label :password, "Senha", class: "block text-sm font-medium text-gray-700" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "rounded border-gray-300" %>
              <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-gray-600" %>
            </div>
          <% end %>

          <%= f.submit "Entrar",
              class: "w-full flex justify-center py-2.5 px-4 rounded-lg text-sm font-semibold text-white cursor-pointer transition-opacity hover:opacity-90",
              style: "background-color:#009C3B;" %>
        </div>
      <% end %>

      <div class="mt-6 text-center text-sm text-gray-500">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
