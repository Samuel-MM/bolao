<% content_for :full_page, true %>
<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="flex justify-center mb-4">
      <div class="w-16 h-16 rounded-full flex items-center justify-center" style="background-color:#009C3B;">
        <span class="text-3xl">⚽</span>
      </div>
    </div>
    <h2 class="text-center text-3xl font-extrabold" style="color:#002776;"><%= @pool.name %></h2>
    <p class="mt-2 text-center text-sm text-gray-500">Você foi convidado para participar deste bolão!</p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-6 shadow rounded-xl sm:px-10">
      <% if @pool.description.present? %>
        <p class="text-sm text-gray-600 mb-6"><%= @pool.description %></p>
      <% end %>

      <div class="space-y-3 text-sm mb-8">
        <div class="flex justify-between">
          <span class="text-gray-500">Aposta mínima</span>
          <span class="font-semibold" style="color:#009C3B;">
            R$ <%= number_with_precision(@pool.min_bet_amount, precision: 2, separator: ',', delimiter: '.') %>
          </span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Jogos</span>
          <span class="font-medium"><%= @pool.matches.count %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Participantes</span>
          <span class="font-medium"><%= @pool.approved_memberships.count %></span>
        </div>
      </div>

      <% if @existing_membership %>
        <div class="text-center py-4">
          <% if @existing_membership.pending? %>
            <span class="inline-block px-4 py-2 bg-yellow-100 text-yellow-800 rounded-lg text-sm font-medium">
              Sua solicitação está aguardando aprovação.
            </span>
          <% elsif @existing_membership.approved? %>
            <span class="inline-block px-4 py-2 bg-green-100 text-green-800 rounded-lg text-sm font-medium">
              Você já é membro deste bolão!
            </span>
            <div class="mt-4">
              <%= link_to "Ver bolão →", pool_path(@pool), class: "text-sm font-semibold", style: "color:#009C3B;" %>
            </div>
          <% else %>
            <span class="inline-block px-4 py-2 bg-red-100 text-red-800 rounded-lg text-sm font-medium">
              Sua solicitação não foi aprovada.
            </span>
          <% end %>
        </div>
      <% elsif @pool.open? %>
        <%= form_with url: pool_join_path(@pool.invite_token), method: :post do %>
          <button type="submit"
                  class="w-full flex justify-center py-2.5 px-4 rounded-lg text-sm font-semibold text-white cursor-pointer transition-opacity hover:opacity-90"
                  style="background-color:#009C3B;">
            Solicitar participação
          </button>
        <% end %>
      <% else %>
        <p class="text-center text-sm text-gray-500">Este bolão está encerrado.</p>
      <% end %>

      <div class="mt-6 text-center">
        <%= link_to "← Ir para o início", root_path, class: "text-sm text-gray-500 hover:underline" %>
      </div>
    </div>
  </div>
</div>
